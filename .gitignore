# ============================================================
# DENY ALL by default (minimal, explicit allow-list)
# ============================================================
*

# Re-allow subdirectories so we can whitelist their contents
!*/

# ============================================================
# Explicitly allowed root files
# ============================================================
!/.gitignore
!/LICENSE
!/README.md
!/PRIVACY.md
!/package.json
!/package-lock.json
!/getemoji.js
!/test.html
!/test2.html
!/todo.txt

# ============================================================
# Data (generator inputs + vendored runtime emoji data)
# ============================================================
!/data/
!/data/**

# ============================================================
# The Chrome extension (source + built assets)
# This is the main deliverable
# ============================================================
!/extension/
!/extension/**

# ============================================================
# Chrome Web Store assets (screenshots, promo tiles, icons)
# ============================================================
!/media/
!/media/**

# ============================================================
# Common junk to keep ignoring (defense in depth)
# ============================================================
node_modules/
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
.env
.env.*
*.tgz
dist/
build/
coverage/
.nyc_output/
